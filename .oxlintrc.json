{
    "$schema": "node_modules/oxlint/configuration_schema.json",
    "extends": [
        "node_modules/@kayahr/oxlint-config/.oxlintrc.json"
    ],
    "env": {
        "node": true,
        "browser": true
    },
    "overrides": [
        {
            "files": [
                "src/demo/**/*",
                "src/test/**/*"
            ],
            "rules": {
                "jsx-a11y/control-has-associated-label": "off"
            }
        }
    ]
}
